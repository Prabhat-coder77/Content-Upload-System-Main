#  Database 
DB_USER=ccu_user
DB_PASSWORD=ccu_password
DB_NAME=coursecontent

#  JWT ─
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=superSecretKeyThatShouldBeChangedInProductionToSomethingLong
JWT_EXPIRATION_SEC=86400
JWT_REFRESH_EXPIRATION_DAYS=7

#  CORS 
# In production set this to your EC2 IP or domain (no trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:5173

#  Storage 
# LOCAL or S3
STORAGE_TYPE=LOCAL
STORAGE_LOCAL_ROOT=/app/uploads

#  File Size Limits 
MAX_FILE_SIZE=50MB
MAX_REQUEST_SIZE=50MB

#  S3 (only required if STORAGE_TYPE=S3) 
# S3_BUCKET=ccu-storage-bucket
# S3_PREFIX=uploads/
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
